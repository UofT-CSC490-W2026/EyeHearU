# Copy to `.env` in this folder and restart Expo.
# Same Wi‑Fi as the API host: use `npm run start:lan` (not --tunnel) so Expo Go can load the bundle reliably.
# Backend: uvicorn ... --host 0.0.0.0 --port 8000
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8000

# Or use LocalTunnel (URL changes every time you restart the tunnel):
# EXPO_PUBLIC_API_URL=https://your-subdomain.loca.lt

EXPO_PUBLIC_API_URL=
