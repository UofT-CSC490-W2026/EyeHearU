# Copy this file to .env and fill in your values
DEBUG=true

# ML model — best_model.pt is downloaded from S3 on first startup
MODEL_PATH=model_cache/best_model.pt
LABEL_MAP_PATH=../ml/i3d_label_map_mvp-sft-full-v1.json
MODEL_DEVICE=cpu

# Gloss-to-English mode:
# - "rule": join+polish (default)
# - "t5": local FLAN-T5 generation
# - "bedrock": AWS Bedrock rewrite (BEDROCK_* below)
GLOSS_ENGLISH_MODE=rule

BEDROCK_REGION=ca-central-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_TIMEOUT_S=20

# S3 model source
AWS_S3_BUCKET=eye-hear-u-public-data-ca1
AWS_S3_REGION=ca-central-1
AWS_S3_MODEL_KEY=models/i3d/modal/candidate-ac-eval-v4/20260325T001403Z/best_model.pt

# AWS credentials (needed for S3 model download)
# Option 1: run `aws configure` to set these globally
# Option 2: set them here:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Firebase (optional — for translation history)
# FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# FIREBASE_PROJECT_ID=your-firebase-project-id
